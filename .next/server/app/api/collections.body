[{"id":1,"type":"collection","title":"صحيح البخاري","short_description":"","numbering_source":"","has_volumes":1,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Sahih al-Bukhari","short_description_en":"Sahih al-Bukhari is a collection of hadith compiled by Imam Muhammad al-Bukhari (d. 256 AH/870 AD) (rahimahullah).\r\n\r\nHis collection is recognized by the overwhelming majority of the Muslim world to be the most authentic collection of reports of the <i>Sunnah</i> of the Prophet Muhammad (ﷺ). It contains over 7500 hadith (with repetitions) in 97 books.\r\n\r\nThe translation provided here is by Dr. M. Muhsin Khan.","numbering_source_en":"The numbering below corresponds with Shaykh Muhammad Fuad `Abd al-Baqi's (rahimahullah) numbering scheme.","last_updated":"2021-09-28 21:18:52"},{"id":2,"type":"collection","title":"صحيح مسلم","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Sahih Muslim","short_description_en":"Sahih Muslim is a collection of hadith compiled by Imam Muslim ibn al-Hajjaj al-Naysaburi (rahimahullah).\r\nHis collection is considered to be one of the most authentic\r\ncollections of the Sunnah of the Prophet (ﷺ), and along with\r\nSahih al-Bukhari forms the \"Sahihain,\" or the \"Two Sahihs.\"\r\nIt contains roughly 7500 hadith (with repetitions) in 57 books.\r\n<br>\r\nThe translation provided here is by Abdul Hamid Siddiqui.","numbering_source_en":"The numbering below corresponds with Shaykh Muhammad Fuad `Abd al-Baqi's (rahimahullah) numbering scheme.","last_updated":"2021-06-03 18:03:09"},{"id":3,"type":"collection","title":"سنن النسائي","short_description":"","numbering_source":"","has_volumes":1,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Sunan an-Nasa'i","short_description_en":"Sunan an-Nasa'i is a collection of hadith compiled by Imam Ahmad an-Nasa'i (rahimahullah).\r\nHis collection is unanimously considered to be one of the six canonical collections of hadith (Kutub as-Sittah)\r\nof the Sunnah of the Prophet (ﷺ).\r\nIt contains roughly 5700 hadith (with repetitions) in 52 books.\r\n","numbering_source_en":"The numbering below corresponds with Shaykh `Abd al-Fattah Abu Ghuddah's (rahimahullah) numbering scheme.","last_updated":"2021-09-13 01:11:53"},{"id":10,"type":"collection","title":"سنن أبي داود","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Sunan Abi Dawud","short_description_en":"Sunan Abi Dawud is a collection of hadith compiled by Imam Abu Dawud Sulayman ibn al-Ash'ath as-Sijistani (rahimahullah). It is widely considered to be among the six canonical collections of hadith (Kutub as-Sittah) of the Sunnah of the Prophet (ﷺ). It consists of 5274 ahadith in 43 books.\r\n<br><br><a href=\"/abudawud/letter\">Letter from Imam Abu Dawud to the people of Makkah explaining his book, terms he uses, and his methodology.</a>","numbering_source_en":"The numbering below corresponds with Shaykh Muhammad Muhi ad-Din `Abd al-Hameed's (rahimahullah) numbering scheme.","last_updated":"2021-05-29 01:48:50"},{"id":30,"type":"collection","title":"جامع الترمذي ","short_description":"","numbering_source":"","has_volumes":1,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Jami` at-Tirmidhi","short_description_en":"Jami` at-Tirmidhi is a collection of hadith compiled by Imam Abu `Isa Muhammad at-Tirmidhi (rahimahullah). His collection is unanimously considered to be one of the six canonical collections of hadith (Kutub as-Sittah) of the Sunnah of the Prophet (ﷺ). It contains roughly 4400 hadith (with repetitions) in 46 books. \r\n","numbering_source_en":"The numbering below corresponds with the numbering scheme started by Shaykh Ahmad Shakir, then continued by Shaykh Muhammad Fu'ad 'Abdul Baaqi, and finished by Shaykh Ibrahim 'Atwah 'Aood (rahimahumullah).","last_updated":"2021-10-08 18:16:39"},{"id":38,"type":"collection","title":"سنن ابن ماجه","short_description":"","numbering_source":"","has_volumes":1,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Sunan Ibn Majah","short_description_en":"Sunan Ibn Majah is a collection of hadith compiled by Imam Muhammad bin Yazid Ibn Majah al-Qazvini (rahimahullah). It is widely considered to be the sixth of the six canonical collection of hadith (Kutub as-Sittah) of the Sunnah of the Prophet (ﷺ). It consists of 4341 ahadith in 37 books.\n","numbering_source_en":"The numbering below corresponds with Shaykh Muhammad Fuad `Abd al-Baqi's (rahimahullah) numbering scheme.","last_updated":"2021-05-04 22:32:40"},{"id":40,"type":"collection","title":" موطأ مالك","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Muwatta Malik","short_description_en":"","numbering_source_en":"","last_updated":"2020-04-19 20:13:41"},{"id":50,"type":"collection","title":"مسند أحمد","short_description":"","numbering_source":"","has_volumes":1,"has_books":1,"has_chapters":0,"status":"incomplete","title_en":"Musnad Ahmad","short_description_en":"Musnad Ahmad is a collection of hadith compiled by Imam Ahmad ibn Hanbal (d. 241 AH/855 AD - rahimahullah). It is one of the most famous and important collections of reports of the Sunnah of the Prophet Muhammad (ﷺ). It is the largest of the main books of hadith containing approximately 28,199 hadith sectioned based on individual Companions. The translation provided here is by Nasir Khattab.","numbering_source_en":"","last_updated":"2020-12-12 14:34:11"},{"id":101,"type":"selection","title":"الأربعون النووية","short_description":"","numbering_source":"","has_volumes":0,"has_books":0,"has_chapters":0,"status":"complete","title_en":"An-Nawawi's 40 Hadith","short_description_en":"","numbering_source_en":"","last_updated":""},{"id":102,"type":"selection","title":"الأربعينات","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":0,"status":"complete","title_en":"Collections of Forty","short_description_en":"","numbering_source_en":"","last_updated":"2021-01-14 09:46:46"},{"id":110,"type":"selection","title":"رياض الصالحين ","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Riyad as-Salihin","short_description_en":"Riyad as-Salihin is a selection of hadith compiled by Imam Yahya ibn Sharaf an-Nawawi. It is one of the most widely known and read books of hadith all over the world, containing approximately 1,900 carefully chosen hadith on ethics, manners, worship, knowledge, and other topics compiled from the Six Books of hadith. It is practical and accessible to Muslims of all levels.","numbering_source_en":"","last_updated":"2021-05-21 20:01:10"},{"id":113,"type":"selection","title":"مشكاة المصابيح","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":1,"status":"incomplete","title_en":"Mishkat al-Masabih","short_description_en":"Mishkat al-Masabih is a selection of hadith compiled by Imam Khatib at-Tabrizi. Imam at-Tabrizi expanded on an earlier selection of hadith named Masabih as-Sunnah by Imam al-Baghawi. Mishkat al-Masabih contains approximately 6,000 hadith chosen from the Six Books, Musnad Ahmad, and various others. It is a comprehensive selection of hadith that covers almost all aspects of Islamic belief, jurisprudence (<i>fiqh</i>), and virtues. The translation provided here is by James Robson.","numbering_source_en":"","last_updated":"2021-05-21 19:59:51"},{"id":115,"type":"collection","title":"الأدب المفرد","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Al-Adab Al-Mufrad","short_description_en":"","numbering_source_en":"","last_updated":"2021-07-14 22:11:27"},{"id":130,"type":"selection","title":"الشمائل المحمدية","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":0,"status":"complete","title_en":"Ash-Shama'il Al-Muhammadiyah","short_description_en":"","numbering_source_en":"","last_updated":"2021-10-08 17:31:34"},{"id":200,"type":"collection","title":"بلوغ المرام","short_description":"","numbering_source":"","has_volumes":0,"has_books":1,"has_chapters":1,"status":"complete","title_en":"Bulugh al-Maram","short_description_en":"","numbering_source_en":"","last_updated":"2021-03-31 02:43:21"},{"id":300,"type":"selection","title":"حصن المسلم","short_description":"","numbering_source":"","has_volumes":0,"has_books":0,"has_chapters":1,"status":"complete","title_en":"Hisn al-Muslim","short_description_en":"","numbering_source_en":"","last_updated":"2021-02-10 20:41:46"}]