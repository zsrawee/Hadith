<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Speech recognition permission -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HadithWidget"
        tools:targetApi="34">

        <!-- Main Activity – handles deep links from the widget -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.HadithWidget">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link scheme for speech practice -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="hadithapp"
                    android:host="practice" />
            </intent-filter>
        </activity>

        <!-- Speech Practice Activity – launched via deep link with hadith ID -->
        <activity
            android:name=".speech.SpeechPracticeActivity"
            android:exported="true"
            android:theme="@style/Theme.HadithWidget"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="hadithapp"
                    android:host="practice" />
            </intent-filter>
        </activity>

        <!-- Glance Widget Receiver -->
        <receiver
            android:name=".widget.HadithWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

    </application>

</manifest>
