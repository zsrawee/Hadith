# ─────────────────────────────────────────────
# Nur al-Hadith — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.
#   cp .env.example .env.local
# ─────────────────────────────────────────────

# ── Speech Practice ──────────────────────────────────────────────────────
# اختر أحد الخيارات التالية (اترك الباقي فارغاً):

# الخيار 1: Hugging Face Inference API (مجاني، 30k طلب/شهر)
# سجل في https://huggingface.co/join → Settings → Access Tokens
HF_TOKEN=hf_your-token-here

# الخيار 2: OpenAI Whisper (يدفع، يعطون رصيد مجاني عند التسجيل)
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Optional: Next.js settings ───────────────────────────────────────────
# NODE_ENV=production
# NEXT_PUBLIC_SITE_URL=https://nur-al-hadith.example.com
